{
	"info": {
		"_postman_id": "sky-take-out-api-v1",
		"name": "Sky-Take-Out API",
		"description": "苍穹外卖项目完整 API 集合\n\n## 使用说明\n1. 先执行 Admin > Employee > Login 获取 adminToken\n2. 先执行 User > Auth > WeChat Login 获取 userToken\n3. Collection 级别 Pre-request Script 会自动在 adminToken 为空时尝试登录\n\n## 变量\n- baseUrl: 服务器地址，默认 http://localhost:8080\n- adminToken: Admin 端 JWT token（自动获取）\n- userToken: User 端 JWT token（需手动设置或通过登录获取）",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "adminToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "userToken",
			"value": "",
			"type": "string"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-login for admin endpoints if token is not set",
					"const requestUrl = pm.request.url.toString();",
					"const isAdmin = requestUrl.includes('/admin/');",
					"const isLogin = requestUrl.includes('/admin/employee/login');",
					"const token = pm.collectionVariables.get('adminToken');",
					"",
					"if (isAdmin && !isLogin && (!token || token === '')) {",
					"    const baseUrl = pm.collectionVariables.get('baseUrl');",
					"    console.log('Admin token not set, attempting auto-login...');",
					"    pm.sendRequest({",
					"        url: baseUrl + '/admin/employee/login',",
					"        method: 'POST',",
					"        header: {",
					"            'Content-Type': 'application/json'",
					"        },",
					"        body: {",
					"            mode: 'raw',",
					"            raw: JSON.stringify({ username: 'admin', password: '123456' })",
					"        }",
					"    }, function (err, res) {",
					"        if (!err && res) {",
					"            const json = res.json();",
					"            if (json.code === 1 && json.data && json.data.token) {",
					"                pm.collectionVariables.set('adminToken', json.data.token);",
					"                console.log('Admin token auto-acquired successfully');",
					"            } else {",
					"                console.warn('Auto-login failed, response:', json.msg || json);",
					"            }",
					"        } else {",
					"            console.error('Auto-login request error:', err);",
					"        }",
					"    });",
					"}"
				]
			}
		}
	],
